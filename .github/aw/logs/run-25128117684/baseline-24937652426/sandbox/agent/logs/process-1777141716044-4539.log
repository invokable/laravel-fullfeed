    "name": "bash",
    "arguments": "{\"command\":\"python - <<'PY'\\nimport json, re\\nfrom pathlib import Path\\nroot = Path('/home/runner/work/laravel-fullfeed/laravel-fullfeed')\\nitems = json.loads((root/'resources/fullfeed/items_all.json').read_text())\\nplus = json.loads((root/'resources/fullfeed/plus.json').read_text())\\nport = (root/'.github/port.md').read_text()\\nplus_urls = {r['data']['url'] for r in plus}\\nported_or_ignored = set(re.findall(r'`([^`]+)`', port))\\nfor rule in items:\\n    url = rule['data'].get('url')\\n    if url in plus_urls:\\n        continue\\n    if url in ported_or_ignored:\\n        continue\\n    print(json.dumps(rule, ensure_ascii=False))\\n    break\\nPY\",\"description\":\"Find first unported rule candidate\",\"mode\":\"sync\",\"initial_wait\":10}",
